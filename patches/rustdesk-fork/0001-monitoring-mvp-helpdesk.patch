+        throw Exception(
+            'assignment helpdesk HTTP ${assignmentResp.statusCode}: ${assignmentResp.body}');
+      }
+
+      final assignmentJson =
+          jsonDecode(assignmentResp.body) as Map<String, dynamic>;
