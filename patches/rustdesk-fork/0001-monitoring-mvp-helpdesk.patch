+class _HelpdeskRequestCard extends StatefulWidget {
+  const _HelpdeskRequestCard();
+
+  @override
+  State<_HelpdeskRequestCard> createState() => _HelpdeskRequestCardState();
+}
+
+class _HelpdeskRequestCardState extends State<_HelpdeskRequestCard> {
+  late final TextEditingController _serverUrlController;
+  late final TextEditingController _displayNameController;
+  late final TextEditingController _summaryController;
+  final Future<String> _peerIdFuture = bind.mainGetMyId();
+  bool _submitting = false;
+  bool _polling = false;
+  String _statusMessage = '';
+  bool _isError = false;
+  HelpdeskTicketSnapshot? _trackedTicket;
+  Timer? _pollTimer;
+
+  @override
+  void initState() {
+    super.initState();
+    _serverUrlController =
+        TextEditingController(text: _resolveInitialHelpdeskServerUrl());
+    _displayNameController =
+        TextEditingController(text: _resolveInitialDisplayName());
+    _summaryController = TextEditingController();
+    Future.microtask(() async {
+      await _restoreTrackedTicket();
+      _startPolling();
+    });
+  }
+
+  @override
+  void dispose() {
+    _pollTimer?.cancel();
+    _serverUrlController.dispose();
+    _displayNameController.dispose();
+    _summaryController.dispose();
+    super.dispose();
+  }
+
+  String _resolveInitialHelpdeskServerUrl() {
+    for (final candidate in [
+      bind.mainGetLocalOption(key: _kHelpdeskServerUrlOption),
+      bind.mainGetEnv(key: 'RUSTDESK_MONITORING_URL'),
+      bind.mainGetLocalOption(key: _kMonitoringServerUrlOption),
+      bind.mainGetLocalOption(key: _kMonitoringServerLegacyOption),
+      'http://127.0.0.1:8080',
+    ]) {
+      final trimmed = candidate.trim();
+      if (trimmed.isNotEmpty) {
+        return trimmed.replaceAll(RegExp(r'\/+$'), '');
+      }
+    }
+    return 'http://127.0.0.1:8080';
+  }
+
+  String _resolveInitialDisplayName() {
+    final displayName =
+        bind.mainGetLocalOption(key: _kMonitoringDisplayNameOption).trim();
+    return displayName;
+  }
+
+  void _startPolling() {
+    _pollTimer?.cancel();
+    _pollTimer = periodic_immediate(const Duration(seconds: 3), () async {
+      await _refreshTrackedTicket();
+    });
+  }
+
+  Future<void> _restoreTrackedTicket() async {
+    final ticketId =
+        bind.mainGetLocalOption(key: _kHelpdeskLastTicketIdOption).trim();
+    if (ticketId.isEmpty) {
+      return;
+    }
+    setState(() {
+      _trackedTicket = HelpdeskTicketSnapshot(
+        ticketId: ticketId,
+        status: bind.mainGetLocalOption(key: _kHelpdeskLastTicketStatusOption),
+      );
+    });
+    await _refreshTrackedTicket(force: true);
+  }
+
+  Future<void> _refreshTrackedTicket({bool force = false}) async {
+    final trackedTicket = _trackedTicket;
+    if (trackedTicket == null || _polling) {
+      return;
+    }
+    if (!force && _isTicketTerminal(trackedTicket.status)) {
+      return;
+    }
+
+    final serverUrl =
+        _serverUrlController.text.trim().replaceAll(RegExp(r'\/+$'), '');
+    if (serverUrl.isEmpty) {
+      return;
+    }
+
+    _polling = true;
+    try {
+      final uri = Uri.parse(
+          '$serverUrl/api/v1/helpdesk/tickets/${Uri.encodeComponent(trackedTicket.ticketId)}');
+      final resp = await http.get(uri);
+      if (resp.statusCode == 404) {
+        return;
+      }
+      if (resp.statusCode < 200 || resp.statusCode >= 300) {
+        throw Exception('ticket status HTTP ${resp.statusCode}: ${resp.body}');
+      }
+
+      final json = jsonDecode(resp.body) as Map<String, dynamic>;
+      final ticketJson = json['ticket'] as Map<String, dynamic>? ?? {};
+      final nextTicket = HelpdeskTicketSnapshot.fromJson(ticketJson);
+      await bind.mainSetLocalOption(
+          key: _kHelpdeskLastTicketStatusOption, value: nextTicket.status);
+
+      if (!mounted) {
+        return;
+      }
+      setState(() {
+        _trackedTicket = nextTicket;
+      });
+    } catch (e) {
+      if (!mounted) {
+        return;
+      }
+      setState(() {
+        _isError = true;
+        _statusMessage = e.toString();
+      });
+    } finally {
+      _polling = false;
+    }
+  }
+
+  bool _isTicketTerminal(String status) {
+    return status == 'resolved' || status == 'cancelled' || status == 'failed';
+  }
+
+  String _statusLabel(String status) {
+    switch (status) {
+      case 'new':
+        return 'Solicitado';
+      case 'queued':
+        return 'En cola';
+      case 'opening':
+        return 'Asignado';
+      case 'in_progress':
+        return 'Conectando';
+      case 'resolved':
+        return 'Finalizado';
+      case 'cancelled':
+        return 'Cancelado';
+      case 'failed':
+        return 'Fallido';
+      default:
+        return status.isEmpty ? 'Sin estado' : status;
+    }
+  }
+
+  Color _statusColor(BuildContext context, String status) {
+    switch (status) {
+      case 'new':
+      case 'queued':
+        return Colors.orange;
+      case 'opening':
+        return Colors.blueAccent;
+      case 'in_progress':
+        return Colors.green;
+      case 'resolved':
+        return Colors.teal;
+      case 'cancelled':
+      case 'failed':
+        return Colors.redAccent;
+      default:
+        return Theme.of(context).textTheme.bodyMedium?.color ?? Colors.grey;
+    }
+  }
+
+  Future<void> _submitHelpdeskRequest() async {
+    if (_submitting) {
+      return;
+    }
+
+    final serverUrl =
+        _serverUrlController.text.trim().replaceAll(RegExp(r'\/+$'), '');
+    if (serverUrl.isEmpty) {
+      setState(() {
+        _isError = true;
+        _statusMessage = 'Falta URL del backend helpdesk';
+      });
+      return;
+    }
+
+    setState(() {
+      _submitting = true;
+      _isError = false;
+      _statusMessage = '';
+    });
+
+    try {
+      final clientId = (await bind.mainGetMyId()).trim();
+      if (clientId.isEmpty) {
+        throw Exception('No se pudo obtener el peer id local');
+      }
+
+      final displayName = _displayNameController.text.trim();
+      await bind.mainSetLocalOption(
+          key: _kHelpdeskServerUrlOption, value: serverUrl);
+      await bind.mainSetLocalOption(
+          key: _kMonitoringDisplayNameOption, value: displayName);
+
+      final uri = Uri.parse('$serverUrl/api/v1/helpdesk/tickets');
+      final resp = await http.post(
+        uri,
+        headers: {'Content-Type': 'application/json'},
+        body: jsonEncode({
+          'client_id': clientId,
+          if (displayName.isNotEmpty) 'client_display_name': displayName,
+          if (_summaryController.text.trim().isNotEmpty)
+            'summary': _summaryController.text.trim(),
+        }),
+      );
+
+      if (resp.statusCode < 200 || resp.statusCode >= 300) {
+        throw Exception(
+            'ticket helpdesk HTTP ${resp.statusCode}: ${resp.body}');
+      }
+
+      final json = jsonDecode(resp.body) as Map<String, dynamic>;
+      final ticket = json['ticket'] as Map<String, dynamic>? ?? {};
+      final ticketId = (ticket['ticket_id'] ?? '').toString();
+      final trackedTicket = HelpdeskTicketSnapshot.fromJson(ticket);
+      await bind.mainSetLocalOption(
+          key: _kHelpdeskLastTicketIdOption, value: ticketId);
+      await bind.mainSetLocalOption(
+          key: _kHelpdeskLastTicketStatusOption, value: trackedTicket.status);
+
+      setState(() {
+        _trackedTicket = trackedTicket;
+        _isError = false;
+        _statusMessage = ticketId.isEmpty
+            ? 'Solicitud enviada'
+            : 'Solicitud enviada. Ticket $ticketId';
+        _summaryController.clear();
+      });
+    } catch (e) {
+      setState(() {
+        _isError = true;
+        _statusMessage = e.toString();
+      });
+    } finally {
+      if (mounted) {
+        setState(() {
+          _submitting = false;
+        });
+      }
+    }
+  }
+
+  @override
+  Widget build(BuildContext context) {
+    return Container(
+      constraints: const BoxConstraints(maxWidth: 600),
+      padding: const EdgeInsets.fromLTRB(20, 16, 20, 16),
+      decoration: BoxDecoration(
+        color: Theme.of(context).cardColor,
+        borderRadius: const BorderRadius.all(Radius.circular(13)),
+        border: Border.all(color: Theme.of(context).dividerColor),
+      ),
+      child: Column(
+        crossAxisAlignment: CrossAxisAlignment.start,
+        children: [
+          Row(
+            children: [
+              const Icon(Icons.support_agent_rounded, size: 18),
+              const SizedBox(width: 8),
+              Text(
+                'Solicitar helpdesk',
+                style: Theme.of(context).textTheme.titleMedium,
+              ),
+            ],
+          ),
+          const SizedBox(height: 12),
+          TextField(
+            controller: _serverUrlController,
+            decoration: const InputDecoration(
+              isDense: true,
+              labelText: 'Backend URL',
+              hintText: 'https://tu-backend-helpdesk',
+            ),
+          ),
+          const SizedBox(height: 10),
+          TextField(
+            controller: _displayNameController,
+            decoration: const InputDecoration(
+              isDense: true,
+              labelText: 'Nombre visible',
+            ),
+          ),
+          const SizedBox(height: 10),
+          TextField(
+            controller: _summaryController,
+            maxLines: 2,
+            decoration: const InputDecoration(
+              isDense: true,
+              labelText: 'Describe el problema',
+              hintText: 'Sin red, impresora, acceso, etc.',
+            ),
+          ),
+          const SizedBox(height: 12),
+          Wrap(
+            spacing: 8,
+            runSpacing: 8,
+            crossAxisAlignment: WrapCrossAlignment.center,
+            children: [
+              ElevatedButton(
+                onPressed: _submitting ? null : _submitHelpdeskRequest,
+                child: Text(_submitting ? 'Enviando...' : 'Solicitar helpdesk'),
+              ),
+              FutureBuilder<String>(
+                future: _peerIdFuture,
+                builder: (context, snapshot) {
+                  final peerId = (snapshot.data ?? '').trim();
+                  if (peerId.isEmpty) {
+                    return const SizedBox.shrink();
+                  }
+                  return Text('Peer ID local: $peerId');
+                },
+              ),
+              if (_trackedTicket != null)
+                OutlinedButton(
+                  onPressed: _polling
+                      ? null
+                      : () => _refreshTrackedTicket(force: true),
+                  child:
+                      Text(_polling ? 'Actualizando...' : 'Actualizar estado'),
+                ),
+            ],
+          ),
+          if (_trackedTicket != null) ...[
+            const SizedBox(height: 12),
+            Container(
+              width: double.infinity,
+              padding: const EdgeInsets.all(12),
+              decoration: BoxDecoration(
+                color: Theme.of(context).scaffoldBackgroundColor,
+                borderRadius: BorderRadius.circular(10),
+              ),
+              child: Column(
+                crossAxisAlignment: CrossAxisAlignment.start,
+                children: [
+                  Text(
+                    'Estado de tu solicitud',
+                    style: Theme.of(context).textTheme.titleSmall,
+                  ),
+                  const SizedBox(height: 6),
+                  Text('Ticket: ${_trackedTicket!.ticketId}'),
+                  Text(
+                    _statusLabel(_trackedTicket!.status),
+                    style: TextStyle(
+                      color: _statusColor(context, _trackedTicket!.status),
+                      fontWeight: FontWeight.w700,
+                    ),
+                  ),
+                  if ((_trackedTicket!.summary ?? '').trim().isNotEmpty)
+                    Text('Resumen: ${_trackedTicket!.summary}'),
+                  if ((_trackedTicket!.assignedAgentId ?? '').trim().isNotEmpty)
+                    Text('Operador: ${_trackedTicket!.assignedAgentId}'),
+                ],
+              ),
+            ),
+          ],
+          if (_statusMessage.isNotEmpty) ...[
+            const SizedBox(height: 10),
+            Text(
+              _statusMessage,
+              style: TextStyle(
+                color: _isError ? Colors.redAccent : Colors.green,
+                fontSize: 12,
+                fontWeight: FontWeight.w600,
+              ),
+            ),
+          ],
+        ],
+      ),
+    );
+  }
+}
+
+class HelpdeskTicketSnapshot {
+  final String ticketId;
+  final String status;
+  final String? summary;
+  final String? assignedAgentId;
+
+  HelpdeskTicketSnapshot({
+    required this.ticketId,
+    required this.status,
+    this.summary,
+    this.assignedAgentId,
+  });
+
+  factory HelpdeskTicketSnapshot.fromJson(Map<String, dynamic> json) {
+    return HelpdeskTicketSnapshot(
+      ticketId: (json['ticket_id'] ?? '').toString(),
+      status: (json['status'] ?? '').toString(),
+      summary: json['summary']?.toString(),
+      assignedAgentId: json['assigned_agent_id']?.toString(),
+    );
+  }
+}
